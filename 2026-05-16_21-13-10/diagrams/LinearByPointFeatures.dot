// Diagram for LinearByPointFeatures
digraph {
	graph [overlap=false rankdir=TB splines=true]
	node [fontname=Arial fontsize=12 margin=0 shape=none]
	edge [fontname=Arial fontsize=11]
	{
		rank=source
		LinearGeometry [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">LinearGeometry</TD></TR></TABLE>> URL="../LinearGeometry" margin=0]
	}
	LinearByPointFeatures [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">LinearByPointFeatures</TD></TR></TABLE>> URL="../LinearByPointFeatures" margin=0]
	{
		rank=max
	}
	subgraph cluster_associated {
		label="" style=invis
		Invis [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD></TD></TR></TABLE>> margin=0 style=invis]
		PointFeatureList [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">PointFeatureList</TD></TR></TABLE>> URL="../PointFeatureList" margin=0]
	}
	LinearByPointFeatures -> LinearGeometry [arrowhead=onormal style=solid]
	LinearByPointFeatures -> Invis [style=invis]
	Invis -> PointFeatureList [style=invis]
	PointFeatureList [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">PointFeatureList</TD></TR></TABLE>> URL="../PointFeatureList" margin=0]
	LinearByPointFeatures -> PointFeatureList [label=hasPointList arrowhead=normal style=solid]
}
