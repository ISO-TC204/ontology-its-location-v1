// Diagram for LinearByPointGeometries
digraph {
	graph [overlap=false rankdir=TB splines=true]
	node [fontname=Arial fontsize=12 margin=0 shape=none]
	edge [fontname=Arial fontsize=11]
	{
		rank=source
		LinearGeometry [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">LinearGeometry</TD></TR></TABLE>> URL="../LinearGeometry" margin=0]
	}
	LinearByPointGeometries [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">LinearByPointGeometries</TD></TR></TABLE>> URL="../LinearByPointGeometries" margin=0]
	{
		rank=max
	}
	subgraph cluster_associated {
		label="" style=invis
		Invis [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD></TD></TR></TABLE>> margin=0 style=invis]
		PointGeometryList [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">PointGeometryList</TD></TR></TABLE>> URL="../PointGeometryList" margin=0]
	}
	LinearByPointGeometries -> LinearGeometry [arrowhead=onormal style=solid]
	LinearByPointGeometries -> Invis [style=invis]
	Invis -> PointGeometryList [style=invis]
	PointGeometryList [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">PointGeometryList</TD></TR></TABLE>> URL="../PointGeometryList" margin=0]
	LinearByPointGeometries -> PointGeometryList [label=hasPointGeometryList arrowhead=normal style=solid]
}
