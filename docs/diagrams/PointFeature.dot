// Diagram for PointFeature
digraph {
	graph [overlap=false rankdir=TB splines=true]
	node [fontname=Arial fontsize=12 margin=0 shape=none]
	edge [fontname=Arial fontsize=11]
	{
		rank=source
		Feature [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">Feature</TD></TR></TABLE>> URL="../Feature" margin=0]
	}
	PointFeature [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">PointFeature</TD></TR></TABLE>> URL="../PointFeature" margin=0]
	{
		rank=max
	}
	subgraph cluster_associated {
		label="" style=invis
		Invis [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD></TD></TR></TABLE>> margin=0 style=invis]
		"its-core_Bearing" [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">its-core:Bearing</TD></TR></TABLE>> URL="https://w3id.org/itsdata/core/v1/Bearing" margin=0]
	}
	PointFeature -> Feature [arrowhead=onormal style=solid]
	PointFeature -> Invis [style=invis]
	Invis -> "its-core_Bearing" [style=invis]
	"its-core_Bearing" [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">its-core:Bearing</TD></TR></TABLE>> URL="https://w3id.org/itsdata/core/v1/Bearing" margin=0]
	PointFeature -> "its-core_Bearing" [label=bearing arrowhead=normal style=solid]
}
